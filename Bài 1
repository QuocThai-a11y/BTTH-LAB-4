#ifndef SOPHUC_H
#define SOPHUC_H 
#include <iostream>
using namespace std;

class SoPhuc{
    private:

    double thuc ;
    double ao ;

    public: 
    SoPhuc(double soThuc = 0 , double soAo = 0 ) : thuc(soThuc) , ao(soAo) {}

    friend istream& operator>>(istream& is , SoPhuc& sp) ;
    friend ostream& operator<<(ostream& os , const SoPhuc& sp) ;
    SoPhuc operator+(const SoPhuc& sp) const ;
    SoPhuc operator-(const SoPhuc& sp) const ;
    SoPhuc operator*(const SoPhuc& sp) const ;
    SoPhuc operator/(const SoPhuc& sp) const ;
    bool operator==(const SoPhuc& sp) const ;
    bool operator!=(const SoPhuc& sp) const ;

};
#endif

#include "SoPhuc.h"
#include <iostream>
#include <cmath>
#include <stdexcept>
using namespace std;

istream& operator>>(istream& is , SoPhuc& sp){
    is>>sp.thuc>>sp.ao ;
    return is ;
}
ostream& operator<<(ostream& os ,const SoPhuc& sp){
    if(sp.ao == 0){
        os << sp.thuc ;
        return os ;
    }
    else if(sp.ao < 0){ 
        os << sp.thuc << " - " << abs(sp.ao)<<"i" ;
        return os ;
    }
    else{
        os << sp.thuc << " + " << sp.ao <<"i" ;   
        return os ;
    }
}
SoPhuc SoPhuc::operator+(const SoPhuc& sp) const {    // ham tong hai so phuc 
    return SoPhuc(this->thuc + sp.thuc, this->ao + sp.ao) ;
}

SoPhuc SoPhuc::operator-(const SoPhuc& sp) const {    // ham hieu hai so phuc
    return SoPhuc(this->thuc - sp.thuc, this->ao - sp.ao) ;
}

SoPhuc SoPhuc::operator*(const SoPhuc& sp) const {    // ham tich hai so phuc
    double PhanThuc = this->thuc*sp.thuc - this->ao*sp.ao ;
    double PhanAo = this->thuc*sp.ao + this->ao*sp.thuc ;
    return SoPhuc(PhanThuc, PhanAo) ;
}

SoPhuc SoPhuc::operator/(const SoPhuc& sp) const {  // ham thuong hai so phuc
    double PhanMau = sp.thuc*sp.thuc + sp.ao*sp.ao ;
    if( PhanMau == 0 ){
        throw runtime_error("khong the chia so phuc cho 0") ;
    }
    double PhanThuc = (this->thuc * sp.thuc + this->ao * sp.ao) / PhanMau ;
    double PhanAo =  ( this->ao * sp.thuc - this->thuc * sp.ao) / PhanMau ;
    return SoPhuc(PhanThuc , PhanAo) ;
}

bool SoPhuc::operator==(const SoPhuc& sp) const {
    return(this->thuc == sp.thuc && this->ao == sp.ao) ;
}
bool SoPhuc::operator!=(const SoPhuc& sp) const {
    return !(this->thuc == sp.thuc && this->ao == sp.ao) ;
}
int main(){
    SoPhuc sp1 , sp2 , sp3 ;
    cout <<" Nhap so phuc thu nhat: ";
    cin >> sp1 ;
    cout <<" Nhap so phuc thu 2: ";
    cin >> sp2 ;
    
    cout <<" Tong hai so phuc: " ;
    sp3 = sp1 + sp2 ;
    cout<< sp3 <<"\n";
    
    cout <<" Hieu hai so phuc: " ;
    sp3 = sp1 - sp2 ;
    cout << sp3 <<"\n";
    
    cout <<" Tich hai so phuc: " ;
    sp3 = sp1 * sp2 ;
    cout << sp3 <<"\n";
    cout <<" Thuong hai so phuc: ";
    try{
        sp3 = sp1 / sp2 ;
        cout<< sp3 << "\n" ;
    }
    catch(const runtime_error& e){
    cout << e.what() << endl;
    }
    if( sp1 == sp2) cout << " hai so phuc 1 va 2 bang nhau " << endl ;
    
    else if( sp1 != sp2 ) cout<< " hai so phuc 1 va 2 khong bang nhau " << endl ;
    
    return 0;
}
